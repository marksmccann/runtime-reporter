{
    "name": "runtime-reporter",
    "version": "0.1.0",
    "description": "Runtime messaging that is convenient in development and secure in production",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "files": [
        "dist"
    ],
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean --sourcemap",
        "prepublishOnly": "npm run build",
        "test": "vitest run --coverage",
        "test:watch": "vitest",
        "lint": "eslint . --format eslint-formatter-compact",
        "lint:fix": "eslint . --fix --format eslint-formatter-compact",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "commit": "cz",
        "release": "release-it",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.ts": [
            "eslint --fix",
            "prettier --write"
        ]
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/marksmccann/runtime-reporter.git"
    },
    "keywords": [
        "runtime",
        "reporter",
        "messaging",
        "console",
        "error handling"
    ],
    "author": {
        "name": "Mark McCann",
        "email": "marksmccann@gmail.com"
    },
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/marksmccann/runtime-reporter/issues"
    },
    "homepage": "https://github.com/marksmccann/runtime-reporter#readme",
    "devDependencies": {
        "@commitlint/cli": "^20.4.2",
        "@commitlint/config-conventional": "^20.4.2",
        "@eslint/js": "^10.0.1",
        "@release-it/conventional-changelog": "^10.0.5",
        "@typescript-eslint/eslint-plugin": "^8.56.0",
        "@typescript-eslint/parser": "^8.56.0",
        "@vitest/coverage-v8": "^4.0.18",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^10.0.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-formatter-compact": "^9.0.1",
        "eslint-plugin-prettier": "^5.5.5",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "prettier": "^3.8.1",
        "release-it": "^19.2.4",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.0",
        "vitest": "^4.0.18"
    }
}
