{
    "plugins": {
        "@release-it/conventional-changelog": {
            "infile": "CHANGELOG.md",
            "preset": { "name": "conventionalcommits" }
        }
    },
    "git": {
        "commitMessage": "chore(release): ${version}",
        "tagName": "v${version}"
    },
    "npm": {
        "publish": false
    }
}
